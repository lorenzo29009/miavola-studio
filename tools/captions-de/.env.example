# Get a free Gemini API key at https://aistudio.google.com/apikey
# Then export it in your shell (see README.md):
#   macOS:   export GEMINI_API_KEY="your-key-here"
#   Windows: setx GEMINI_API_KEY "your-key-here"
GEMINI_API_KEY=

# Optional, per-project. Leave empty to keep captions brand-agnostic.
# CAPTION_BRAND  — canonical brand spelling (write it EXACTLY as it should appear,
#                  including case — lowercase stays lowercase). The brand and every
#                  CAPTION_TERMS entry are ENFORCED in the output: spacing/hyphen/
#                  case variants ("Mia Vola", "mia-vola") and near-miss mishearings
#                  ("Miawola", "L-tyroxin") are rewritten to the canonical form, and
#                  they're listed to Gemini as preferred spellings.
#                  Example: CAPTION_BRAND=miavola
# CAPTION_TERMS  — comma-separated extra canonical spellings (product names,
#                  ingredients, …), enforced the same way.
#                  Example: CAPTION_TERMS=L-Thyroxin, Selen
CAPTION_BRAND=
CAPTION_TERMS=
