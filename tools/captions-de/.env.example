# Get a free Gemini API key at https://aistudio.google.com/apikey
# Then export it in your shell (see README.md):
#   macOS:   export GEMINI_API_KEY="your-key-here"
#   Windows: setx GEMINI_API_KEY "your-key-here"
GEMINI_API_KEY=

# Optional, per-project. Leave empty to keep captions brand-agnostic.
# CAPTION_BRAND  — canonical brand spelling. Mis-transcriptions ("Mia Vola",
#                  "mia-vola", …) are normalized to it, and it's listed to
#                  Gemini as a preferred spelling. Example: CAPTION_BRAND=mariposa
# CAPTION_TERMS  — comma-separated extra spellings Gemini should preserve when
#                  the audio matches (product names, ingredients, …).
#                  Example: CAPTION_TERMS=Selen, L-Tyroxin
CAPTION_BRAND=
CAPTION_TERMS=
